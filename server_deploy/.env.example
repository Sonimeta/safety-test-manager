# ============================================================
# CONFIGURAZIONE SERVER SyncAPI - Safety Test Manager
# ============================================================
# Copia questo file in .env e personalizza i valori.
# Il file .env deve stare NELLA STESSA CARTELLA da cui avvii
# SyncAPI_Server.exe (o start_server.bat).
#
# NON condividere questo file!

# --- Database PostgreSQL ---
# Il server SyncAPI gira sulla STESSA macchina di PostgreSQL,
# quindi l'host e' "localhost".
DB_NAME=safety_test_db
DB_USER=safety_user
DB_PASSWORD=la_tua_password_db
DB_HOST=localhost
DB_PORT=5432

# --- Sicurezza JWT ---
# IMPORTANTE: Usa la STESSA chiave che usavi sul .env locale,
# altrimenti i token dei client gia' loggati non funzioneranno.
#
# Per generare una nuova chiave (se serve):
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CAMBIA-QUESTA-CHIAVE-SEGRETA
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# --- HTTPS / SSL ---
# OBBLIGATORIO per server con IP pubblico!
# Genera il certificato con lo script genera_certificato.ps1
# I percorsi sono relativi alla cartella di lavoro (dove c'e' questo .env)
SSL_CERTFILE=ssl\server.crt
SSL_KEYFILE=ssl\server.key
