[req]
default_bits = 2048
prompt = no
default_md = sha256
x509_extensions = v3_req
distinguished_name = dn

[dn]
C = IT
ST = Italia
L = Test
O = Safety Test Manager
OU = SyncAPI
CN = SyncAPI Server

[v3_req]
subjectAltName = @alt_names
basicConstraints = CA:TRUE
keyUsage = digitalSignature, keyEncipherment, keyCertSign
extendedKeyUsage = serverAuth

[alt_names]
IP.1 = 127.0.0.1
IP.2 = 0.0.0.0
DNS.1 = localhost
